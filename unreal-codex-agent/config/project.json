{
  "project_name": "unreal-codex-agent-demo",
  "project_version": "0.2.0",
  "environment": "development",
  "default_room_type": "living_room",
  "engine": {
    "platform": "uefn",
    "uefn_version": "current",
    "units": "centimeters",
    "supported_scripting_workflows": [
      "verse_devices",
      "fortnite_devices",
      "scene_graph"
    ],
    "python_editor_script_plugin_required": false,
    "remote_python_execution_required": false,
    "scene_graph_beta": true
  },
  "paths": {
    "data_dir": "data",
    "catalog_dir": "data/catalog",
    "catalog_db": "data/catalog/asset_catalog.sqlite",
    "catalog_jsonl": "data/catalog/asset_catalog.jsonl",
    "quarantine_jsonl": "data/catalog/quarantine.jsonl",
    "preview_dir": "data/previews",
    "session_dir": "data/sessions",
    "cache_dir": "data/cache",
    "placement_pose_profiles_json": "data/cache/placement_pose_profiles.json",
    "log_dir": "logs"
  },
  "scene_state": {
    "backend": "auto"
  },
  "uefn": {
    "project_type": "uefn",
    "scene_graph_enabled": true,
    "scene_graph_beta": true,
    "fortnite_devices_enabled": true,
    "creative_devices_enabled": true,
    "verse_root": "uefn/verse",
    "generated_root": "uefn/verse/generated",
    "export_root": "data/uefn_bridge"
  },
  "verse": {
    "action_backend": "auto",
    "auto_select_after_apply": false,
    "auto_focus_after_apply": false,
    "auto_optimize_floor_orientation": true,
    "generate_cycle_exports": true,
    "device_strategy": "creative_device",
    "scene_graph_strategy": "entity_component",
    "fortnite_device_strategy": "authored_device_links"
  },
  "asset_ai": {
    "enabled": true,
    "force_rebuild_on_start": false,
    "incremental_updates_enabled": true,
    "min_trust_for_auto_place": 85,
    "min_trust_for_shortlist": 70,
    "quarantine_below_trust": 50,
    "write_metadata_back_to_catalog": true,
    "generate_preview_images": true,
    "default_preview_width": 1024,
    "default_preview_height": 1024
  },
  "capture": {
    "enabled": true,
    "backend": "auto",
    "default_profile": "default_room",
    "max_images_per_packet": 8,
    "burst_capture_after_edit": true,
    "save_packets": true
  },
  "integrations": {
    "preferred_runtime": "uefn_verse",
    "preferred_bridge": "uefn_mcp",
    "free_first_policy": true,
    "preferred_building_tools": [
      "fortnite_devices",
      "scene_graph",
      "verse",
      "pcg_framework",
      "prefabricator_ue5_reference_only"
    ],
    "uefn_mcp": {
      "enabled": true,
      "default_port": 8765,
      "max_port": 8770,
      "vendor_root": "vendor/uefn-mcp-server",
      "server_script": "vendor/uefn-mcp-server/mcp_server.py",
      "listener_script": "vendor/uefn-mcp-server/uefn_listener.py",
      "init_script": "vendor/uefn-mcp-server/init_unreal.py",
      "client_config_path": ".mcp.json"
    },
    "uefn_toolbelt": {
      "enabled": true,
      "vendor_root": "vendor/uefn-toolbelt",
      "python_root": "vendor/uefn-toolbelt/Content/Python",
      "package_root": "vendor/uefn-toolbelt/Content/Python/UEFN_Toolbelt",
      "init_script": "vendor/uefn-toolbelt/init_unreal.py",
      "mcp_server_script": "vendor/uefn-toolbelt/mcp_server.py",
      "client_script": "vendor/uefn-toolbelt/client.py",
      "launcher_script": "vendor/uefn-toolbelt/launcher.py",
      "docs_root": "vendor/uefn-toolbelt/docs"
    },
    "prefabricator": {
      "enabled": false,
      "repo_url": "https://github.com/unknownworlds/prefabricator-ue5",
      "plugin_folder_name": "Prefabricator",
      "prefer_prefabs_for_mount_types": [
        "opening",
        "corner",
        "roof"
      ]
    }
  },
  "validation": {
    "enabled": true,
    "max_auto_retries_per_zone": 4
  },
  "orchestrator": {
    "auto_start": true,
    "auto_create_session": true,
    "session_name": "default_session",
    "save_action_history": true,
    "save_score_history": true,
    "use_undo_groups": true,
    "max_zone_iterations": 6
  },
  "developer_tools": {
    "enabled": true,
    "experimental": true,
    "scene_xray": {
      "enabled": true,
      "auto_generate_per_cycle": true,
      "default_xray_on": true,
      "default_show_identified": true,
      "default_show_undefined": true,
      "default_show_labels": true,
      "default_show_tool_list": true
    }
  }
}